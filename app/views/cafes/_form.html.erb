<%= form_with model: @cafe, url: (@cafe.persisted? ? cafe_path(@cafe) : cafes_path), local: true do |f| %>
  <%= render "shared/error_messages", object: f.object %>

  <div class="mb-3">
    <%= f.label :name, "店名", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :address, "住所", class: "form-label" %>
    <%= f.text_field :address, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "説明", class: "form-label" %>
    <%= f.text_area :description, rows: 4, class: "form-control" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "戻る", cafes_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

