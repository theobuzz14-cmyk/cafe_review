<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">カフェ一覧</h1>
      <p class="text-muted mb-0">気になるカフェのレビューを見つけましょう。</p>
    </div>
    <% if user_signed_in? %>
      <%= link_to "カフェを追加", new_cafe_path, class: "btn btn-primary" %>
    <% else %>
      <%= link_to "ログイン", new_session_path, class: "btn btn-outline-primary" %>
    <% end %>
  </div>

  <div class="row g-3">
    <% @cafes.each do |cafe| %>
      <div class="col-md-6">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h2 class="h5 card-title mb-2"><%= link_to cafe.name, cafe_path(cafe), class: "text-decoration-none" %></h2>
            <p class="text-muted mb-1"><%= cafe.address.presence || "住所未登録" %></p>
            <p class="mb-0"><small>レビュー数: <%= cafe.reviews.count %></small></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
