<!DOCTYPE html>
<html>
  <head>
    <title>Cafe Review Local</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <%= stylesheet_link_tag :app %>
  </head>

  <body>
    <header class="container py-3">
      <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
        <%= link_to "Cafe Review", root_path, class: "h5 mb-0 text-decoration-none" %>
        <div class="d-flex align-items-center gap-2">
          <% if user_signed_in? %>
            <span class="text-muted"><%= current_user %> さん</span>
            <%= button_to "ログアウト", sessions_path, method: :delete, class: "btn btn-sm btn-outline-secondary" %>
          <% else %>
            <%= link_to "ログイン", new_session_path, class: "btn btn-sm btn-outline-primary" %>
          <% end %>
        </div>
      </div>

      <% flash.each do |type, message| %>
        <div class="mt-2 alert <%= type == "alert" ? "alert-danger" : "alert-success" %>">
          <%= message %>
        </div>
      <% end %>
    </header>

    <%= yield %>
  </body>
</html>
