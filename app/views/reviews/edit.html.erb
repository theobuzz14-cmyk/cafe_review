<div class="container py-4">
  <h1 class="h3 mb-4">レビュー編集</h1>

  <%= form_with model: @review, local: true do |f| %>
    <%= render "shared/error_messages", object: f.object %>

    <div class="mb-3">
      <%= f.label :rating, "評価 (1〜5)", class: "form-label" %>
      <%= f.number_field :rating, in: 1..5, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :body, "コメント", class: "form-label" %>
      <%= f.text_area :body, rows: 4, class: "form-control" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "更新する", class: "btn btn-primary" %>
      <%= link_to "戻る", cafe_path(@review.cafe), class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
<h1>Reviews#edit</h1>
