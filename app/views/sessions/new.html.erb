<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="h4 mb-3">簡易ログイン</h1>
          <p class="text-muted">ユーザー名だけでログインする学習用フォームです。</p>

          <%= form_with url: sessions_path, method: :post, local: true do |f| %>
            <div class="mb-3">
              <%= label_tag :username, "ユーザー名", class: "form-label" %>
              <%= text_field_tag :username, "", class: "form-control", placeholder: "例: demo_user" %>
            </div>
            <div class="d-grid gap-2">
              <%= f.submit "ログイン", class: "btn btn-primary" %>
              <%= link_to "一覧へ戻る", cafes_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<h1>Sessions#new</h1>
